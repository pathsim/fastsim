{#-
  ASAP2 (A2L) description of the generated model: MEASUREMENT entries for
  time / states / outputs / inputs / discrete memory and CHARACTERISTIC
  entries for the tunable parameters, addressed via SYMBOL_LINK against one
  global model instance plus the field's byte offset within `<name>_t`.
  Offsets follow the natural-alignment layout shared by the mainstream ABIs
  (x86-64 SysV, MSVC x64, AAPCS64); `size_t` is assumed 8 bytes (64-bit
  target). Calibration tools (CANape, INCA) resolve the instance symbol from
  the ELF and add the offset.
-#}
/* {{ file_base }}.a2l - ASAP2 measurement/calibration description for the
   {{ name }} model, generated by fastsim {{ version }}. Addresses are
   SYMBOL_LINK-relative to one global instance:  {{ real }} layout,
   64-bit target assumed for size_t.  Define the instance as a non-static
   global named "{{ symbol }}" (e.g.  `{{ name }}_t {{ symbol }};`), or remap
   the SYMBOL_LINK name in your calibration tool. */
ASAP2_VERSION 1 71
/begin PROJECT {{ name }} "fastsim generated model"
  /begin MODULE {{ name }} "generated by fastsim {{ version }}"

    /begin MOD_COMMON ""
      BYTE_ORDER MSB_LAST
    /end MOD_COMMON

{% if compu_scale is none %}
    /begin COMPU_METHOD CM_IDENTITY "identity conversion"
      IDENTICAL "%.15g" ""
    /end COMPU_METHOD
{% else %}
    /* Fixed point: phys = {{ compu_scale }} * int (Q scaling). */
    /begin COMPU_METHOD CM_IDENTITY "Q-format scaling"
      LINEAR "%.15g" ""
      COEFFS_LINEAR {{ compu_scale }} 0
    /end COMPU_METHOD
{% endif %}

    /begin RECORD_LAYOUT RL_SCALAR
      FNC_VALUES 1 {{ dtype }} ROW_DIR DIRECT
    /end RECORD_LAYOUT

{% for c in characteristics %}
    /begin CHARACTERISTIC {{ c.name }} "{{ c.desc }}"
      VALUE 0x0 RL_SCALAR 0 CM_IDENTITY {{ lo }} {{ hi }}
      SYMBOL_LINK "{{ symbol }}" {{ c.offset }}
    /end CHARACTERISTIC
{% endfor %}
{% for m in measurements %}
    /begin MEASUREMENT {{ m.name }} "{{ m.desc }}"
      {{ dtype }} CM_IDENTITY 1 0 {{ lo }} {{ hi }}
      ECU_ADDRESS 0x0
{% if m.writable %}
      READ_WRITE
{% endif %}
      SYMBOL_LINK "{{ symbol }}" {{ m.offset }}
    /end MEASUREMENT
{% endfor %}
  /end MODULE
/end PROJECT
