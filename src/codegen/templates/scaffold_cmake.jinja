{#-
  Editable CMake scaffold emitted under `scaffold=true`: the generated model
  as a static library (link into firmware/app) plus the demo executable over
  `<file_base>_main.c`. Plain CMake, no platform assumptions, cross-compile
  friendly (pass your toolchain file as usual).
-#}
# CMakeLists.txt - build scaffold for the generated {{ name }} model.
#
# Generated by fastsim {{ version }} as an EDITABLE starting point (a rerun
# with scaffold=true overwrites it). Usage:
#
#   cmake -B build && cmake --build build
#   ./build/{{ name }}_demo > trajectory.csv
#
# Cross-compiling: pass your toolchain file as usual
# (cmake -B build -DCMAKE_TOOLCHAIN_FILE=...).
cmake_minimum_required(VERSION 3.13)
project({{ name }} C)

set(CMAKE_C_STANDARD 99)
set(CMAKE_C_STANDARD_REQUIRED ON)

# The generated model as a static library - link this into your application.
add_library({{ name }} STATIC
{% for f in model_sources %}
    {{ f }}
{% endfor %}
)
target_include_directories({{ name }} PUBLIC ${CMAKE_CURRENT_SOURCE_DIR})
# No FMA contraction: the sources carry `#pragma STDC FP_CONTRACT OFF`, but gcc
# ignores that pragma and contracts by default under optimization - which can
# shift a scheduled event by one step at an exactly-aligned boundary. The flag
# keeps the C trajectory bit-identical to the fastsim reference.
target_compile_options({{ name }} PRIVATE
    $<$<OR:$<C_COMPILER_ID:GNU>,$<C_COMPILER_ID:Clang>,$<C_COMPILER_ID:AppleClang>>:-ffp-contract=off>)
# The model needs libm only (C99 + <math.h>); MSVC bundles it in the CRT.
if(UNIX)
    target_link_libraries({{ name }} PUBLIC m)
endif()

# Demo driver: steps the model and prints a CSV trajectory to stdout.
add_executable({{ name }}_demo {{ file_base }}_main.c)
target_link_libraries({{ name }}_demo PRIVATE {{ name }})
