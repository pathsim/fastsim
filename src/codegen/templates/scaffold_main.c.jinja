#include <stdio.h>
#include "{{ entry_header }}"

/* Simulated span and step; override at compile time with
   -DFASTSIM_DURATION=... / -DFASTSIM_DT=... */
#ifndef FASTSIM_DURATION
#define FASTSIM_DURATION 10.0
#endif
#ifndef FASTSIM_DT
#define FASTSIM_DT 1e-3
#endif

/* --- HAL hooks --------------------------------------------------------------
   Wire your real I/O here. `read_inputs` runs before each step (write sensor
   values into the model, e.g.
       {{ name }}_set_signal(m, {{ name | upper }}_SIG_<input>, read_adc());
   ), `write_outputs` after it (read results out, e.g. drive a DAC). The
   defaults print a CSV trajectory to stdout. */

static void read_inputs({{ name }}_t *m) {
    (void)m;
}

static void write_outputs(const {{ name }}_t *m) {
    printf("%.17g", (double)m->time);
{% for s in print_sigs %}
    printf(",%.17g", (double){{ name }}_get_signal(m, {{ name | upper }}_SIG_{{ s }}));
{% endfor %}
    printf("\n");
}

int main(void) {
    static {{ name }}_t m;
    {{ name }}_init(&m);

    /* CSV header, then one row per step. */
    printf("time{% for s in print_sigs %},{{ s }}{% endfor %}\n");
    write_outputs(&m);

    const long fs_n = (long)(FASTSIM_DURATION / FASTSIM_DT + 0.5);
    for (long fs_k = 0; fs_k < fs_n; ++fs_k) {
        read_inputs(&m);
        {{ name }}_step(&m, FASTSIM_DT);
        write_outputs(&m);
    }
    return 0;
}
